CM freq=2440	Resonant frequency
CM AH=3	Antenna height in wavelength
CM S=0.0082	Adj gap when testing              0.0082              0.0082  =   1MM gap for WiFi band. Help in adjusting VSWR.
CM W=0.0080	Wire thickness                        0.0020              0.0020 @ 2.45 ghz is diameter (0.50 mm) of one of the conductor of ethernet cable
CM A=0.134084	Radiating wires length             0.73                  90 to 100 mm length  for WiFi band depending on number of elements
CM R=A	Ring wire length                      0.96-A               25 to 28 mm length for WiFi band depending on number of elements
CM CF=6.2832	2*pi  or 2 * 3.1416 = 6.2832 Conversion factor for ring wire length
CM EL=2	Number of extra  elements       2 to 9                651 mm length for 2 elements for WiFi band covering whole band under 2:1 VSWR
CM G=0.32	0.32 with 1 reflector , 0.38 with 2 reflectors and 0.65 with 7 wire reflectors.
CM RT=21	Reflector thickness                         35 or 21 with 7 wire reflectors.
CM RH=2.5	Reflector height                             EL+1      or  (EL*2)+1 with flat metal reflector.
CM VF=1	Velocity factor of coax cable.        0.66
CM STUB1=172	Stub from antenna to feedpoint     172 ( Any length of stub in MM)
CM STUB2=43.30848	Stub length in MM.                        53             Make sure to check VSWR & bandwidth with VNA and adjust this to cover whole desired bandwidth.
CM RW=1.60	Reflector width        1.6          0 TO 1.7            Decides antenna pattern
CM Rx=RW/2, Rnx=2	Reflector width  / 2 , number of wires
CM Ry=RH/2, Rny=10	Reflector height / 2 , number of wires
CM SRW=1.20	1.20
CM SRA=2.35	2.35
CM RG=0.61	0.61
CM HD=1	1.70
CM HW=1	2.00
CM 
CM 
CM 
CM 
CM Helix	1	10	S	S	R/CF	R/CF	R/CF	R/CF	W				Create center ring
CM Copy/move	0	0	0	0	0	0	0	A/2	1				Move center ring on Z axis
CM Copy/move	10	EL	0	0	0	0	0	A+S	1				Create exra rings and copy on Z axis
CM Wire	2	10	R/CF	0	(A/2)+S	R/CF	0	A+(A/2)+S	W				Wire from center ring to second ring
CM Wire	3	10	R/CF	0	A+(A/2)+(S*2)	R/CF	0	(A*2)+(A/2)+(S*2)	W				Wire from second ring to third ring
CM Copy/move	20	EL-1	0	0	0	0	0	A+S	3				Create wires and copy on Z axis
CM Mirror	100	0	0	1									
CM Wire	4	11	R/CF	0	-A/2	R/CF	0	A/2	W				Center radiator
CM Wire	5	10	0	0	-A/2	0	0	A/2	W				Reflector
CM Wire	6	1	-W	0.20	0	W	0.20	0	W				Feedpoint
CM Wire	7	1	-W	0.40	0	W	0.40	0	W				Stub for adjusing VSWR
CM P-multip	Rnx*2	Rny*2	-RG	-Rx	-Ry	-RG	Rx	-Ry	-RG	Rx	Ry		
CM P-multip	Rny*2	5	-RG	-Rx	-Ry	-RG	-Rx	Ry	-RG/2	-SRA/2	Ry		
CM P-multip	Rny*2	5	-RG	Rx	Ry	-RG	Rx	-Ry	-RG/2	SRA/2	-Ry		
CM P-multip	Rny*2	5	-RG/2	-SRA/2	-Ry	-RG/2	-SRA/2	Ry	SRW	-SRA	Ry		
CM P-multip	Rny*2	5	-RG/2	SRA/2	Ry	-RG/2	SRA/2	-Ry	SRW	SRA	-Ry		
CM Wire	500	3	-RG	-Rx	0	-RG	Rx	0	W				
CM Wire	501	3	-RG	-Rx	0	-RG/HD	-SRA/HW	0	W				
CM Wire	502	3	-RG/HD	-SRA/HW	0	SRW	-SRA	0	W				
CM Wire	503	3	-RG	Rx	0	-RG/HD	SRA/HW	0	W				
CM Wire	504	3	-RG/HD	SRA/HW	0	SRW	SRA	0	W				
CM Wire	505	3	-RG/HD	SRA/HW	0	-RG/HD	-SRA/HW	0	W				
CM Wire	506	3	SRW	SRA	0	SRW	-SRA	0	W				
CM Wire	507	3	-RG	0	0	SRW	0	0	W				
CM Copy/move	0	0	90	0	0	0	0	AH					
